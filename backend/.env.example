# ============================================================
# KEPLER AI Backend — Environment Variables
# ============================================================
# Copy this file to .env for local development.
# NEVER commit a filled-in .env file to version control.
# ============================================================


# ── App ──────────────────────────────────────────────────────
PROJECT_NAME=KEPLER AI
API_V1_STR=/api/v1

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_string

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://keplerai.vercel.app,http://localhost:5173

# ── PostgreSQL ───────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# For Railway: set DATABASE_URL directly in the dashboard.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orbital_guardian

# ── Space-Track.org (optional — falls back to Celestrak) ─────
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# ── Celestrak fallback ────────────────────────────────────────
SATELLITE_PROVIDER_PRIORITY=space-track,celestrak,cache
CELESTRAK_BASE_URL=https://celestrak.org

# ── OpenAI (optional) ─────────────────────────────────────────
OPENAI_API_KEY=

# ── NASA DONKI Space Weather API ─────────────────────────────
NASA_DONKI_API_KEY=DEMO_KEY

# ── Celery / Redis / RabbitMQ ────────────────────────────────
# Only needed if running separate Celery workers.
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
